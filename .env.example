# Server
PORT=3001
CORS_ORIGIN=*

# AMap Web Service
AMAP_WEB_KEY=
AMAP_WEB_SIG=
COMMUTE_CONCURRENCY=3

# TOS / S3-compatible storage
TOS_ENDPOINT=
TOS_REGION=cn-beijing
TOS_BUCKET=
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=

# AI provider: openai | doubao
AI_PROVIDER=openai

# OpenAI (SDK)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini

# Doubao (HTTP)
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-1-6-250615
